#!/usr/bin/env bash
# xcbox — run a sandboxed coding agent on the Xcode/Swift project in the current
# directory. The agent sees ONLY this project; it builds/tests on the host via
# XcodeBuildMCP. Usage: cd ~/MyApp && xcbox [up|list|status|stop|logs|rm|doctor]
set -euo pipefail

# Resolve through symlinks so `xcbox` works when installed as a symlink on PATH
# (xcbox-lib.sh lives next to the REAL script, not next to the symlink).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  dir=$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)
  SOURCE=$(readlink "$SOURCE")
  case $SOURCE in /*) ;; *) SOURCE="$dir/$SOURCE" ;; esac
done
DIR=$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)
. "$DIR/xcbox-lib.sh"

usage() {
  cat >&2 <<'EOF'
xcbox — sandboxed coding agent for Xcode/Swift projects (project-only)

Usage: xcbox [command]

Commands:
  up        (default) bring up gateway + project sandbox and enter it
  list      list all xcbox containers and retained project homes
  status    show gateway/box/agent/MCP state for this project
  stop      stop this project's box (add --gateway to also stop the gateway)
  logs      tail the build gateway log (-f follows; --lines N controls history)
  rm        remove this project's box (keeps ~/.xcbox-home)
  doctor    check host prerequisites
  help      show this help
EOF
}

cmd_up() {
  local requested proj name mount_root
  requested="${PROJECT:-$(pwd)}"
  # 1. Resolve a canonical project directory. This accepts a project ancestor
  # or a unique nested project from the repository root.
  proj=$(require_project_dir "$requested") || return
  name=$(sanitize_name "$proj")
  # Mount the git repo root (not just $proj) so .git is in the box and the agent
  # can commit/push — the Xcode project often lives in a subdir of the repo.
  mount_root=$(repo_mount_root "$proj")
  # 2. Daemon + host build gateway.
  if ! container ls >/dev/null 2>&1; then echo "==> starting container service"; container system start; fi
  if legacy_box_detected "$proj" "$name"; then
    print_legacy_box_migration "$proj" "$name"
    return 1
  fi
  ensure_container_gateway_route
  ensure_gateway
  # 3. Project sandbox (mounts the repo root; box keyed to $proj) + provisioning.
  ensure_box "$name" "$mount_root" "$proj"
  carry_git_identity "$name"
  ensure_agent "$name"
  register_mcp "$name"
  # 4. Enter.
  echo "==> entering '$name' (sandboxed to $mount_root; type 'exit' to leave; box keeps running)"
  if [ "$mount_root" != "$proj" ]; then
    echo "    (mounted the git repo root so commit/push work; you start at $proj)"
  fi
  echo "    run 'claude' and use /login only if prompted. Then ask it to build/test the app."
  exec container exec -it -w "$proj" -e PATH="$INNER_PATH" "$name" bash
}

_ok()   { echo "  OK   $1"; }
_fail() { echo "  FAIL $1 — $2"; return 1; }

_chk_arch() {
  [ "$(uname -m)" = "arm64" ] && _ok "Apple Silicon" || _fail "Apple Silicon" "xcbox requires an Apple Silicon Mac"
}
_chk_macos() {
  [ "$(uname -s)" = "Darwin" ] && _ok "macOS ($(sw_vers -productVersion 2>/dev/null))" || _fail "macOS" "xcbox runs on macOS only"
}
_chk_xcode() {
  xcodebuild -version >/dev/null 2>&1 && _ok "Xcode ($(xcodebuild -version 2>/dev/null | head -1))" || _fail "Xcode" "install Xcode and run: sudo xcode-select -s /Applications/Xcode.app"
}
_chk_node_npm() {
  node_supported && command -v npm >/dev/null 2>&1 \
    && _ok "Node/npm ($(node --version 2>/dev/null) / npm $(npm --version 2>/dev/null))" \
    || _fail "Node/npm" "install Node.js 20 or newer"
}
_chk_container() {
  command -v container >/dev/null 2>&1 && _ok "container CLI ($(container --version 2>/dev/null | head -1))" || _fail "container CLI" "install Apple's container CLI"
}
_chk_gateway_route() {
  if ! gateway_bind_is_loopback; then
    _fail "gateway route" "XCBOX_GATEWAY_BIND_HOST=$GATEWAY_BIND_HOST is not loopback-only"
  elif container_host_bridge_configured; then
    _ok "gateway route ($GATEWAY_HOST → host loopback)"
  else
    _fail "gateway route" "run: sudo container system dns create $GATEWAY_HOST --localhost $GATEWAY_LOCALHOST_IP"
  fi
}
_chk_git_identity() {
  [ -n "$(git config --global user.name 2>/dev/null)" ] && [ -n "$(git config --global user.email 2>/dev/null)" ] \
    && _ok "git identity ($(git config --global user.name))" \
    || _fail "git identity" "set it: git config --global user.name '…' && git config --global user.email '…'"
}
_chk_ssh_agent() {
  [ -n "${SSH_AUTH_SOCK:-}" ] && ssh-add -l >/dev/null 2>&1 && _ok "SSH agent (keys loaded)" \
    || _fail "SSH agent" "start it and add a key: eval \"\$(ssh-agent)\" && ssh-add"
}

cmd_doctor() {
  echo "xcbox doctor — host prerequisites:"
  local rc=0
  _chk_arch         || rc=1
  _chk_macos        || rc=1
  _chk_xcode        || rc=1
  _chk_node_npm     || rc=1
  _chk_container    || rc=1
  _chk_gateway_route || rc=1
  _chk_git_identity || rc=1
  _chk_ssh_agent    || rc=1
  [ "$rc" = 0 ] && echo "all good." || echo "some checks failed (see FAIL lines above)."
  return "$rc"
}

cmd_status() {
  local requested proj name box_gateway_ok=0
  requested="${PROJECT:-$(pwd)}"
  proj=$(project_context_dir "$requested") || return
  name=$(sanitize_name "$proj")
  echo "xcbox status — $proj"
  container ls >/dev/null 2>&1 && echo "  OK   container daemon running" || echo "  --   container daemon not running"
  if runtime_ready; then
    echo "  OK   gateway runtime: built-in bridge, MCP SDK $(runtime_package_version @modelcontextprotocol/sdk), xcodebuildmcp $(runtime_package_version xcodebuildmcp) (locked)"
  else
    echo "  --   gateway runtime missing/outdated (next 'xcbox up' runs npm ci)"
  fi
  if gateway_up && gateway_alive && gateway_bind_matches; then echo "  OK   build gateway serving on $GATEWAY_BIND_HOST:$GATEWAY_PORT (pid $(cat "$XCBOX_HOME/gateway.pid"))"
  elif gateway_up; then echo "  FAIL gateway answering on :$GATEWAY_PORT but ownership/bind is unverified"
  elif gateway_alive; then echo "  --   gateway pid alive but not answering yet"
  else echo "  --   build gateway not running"; fi
  if legacy_box_detected "$proj" "$name"; then
    echo "  FAIL legacy box '$(legacy_box_name "$proj")' needs explicit migration to '$name'"
  elif box_exists "$name"; then
    box_running "$name" && echo "  OK   box '$name' running" || echo "  --   box '$name' exists (stopped)"
    box_home_isolated "$name" \
      && echo "  OK   isolated per-project home ($(box_home_dir "$name"))" \
      || echo "  FAIL box /root uses a legacy/shared mount (recreate with 'xcbox rm', then 'xcbox up')"
    if box_running "$name"; then
      container exec "$name" sh -c 'test -x /root/.npm-global/bin/claude' 2>/dev/null \
        && echo "  OK   agent installed" || echo "  --   agent not installed"
      container exec -e PATH="$INNER_PATH" "$name" sh -c 'claude mcp list 2>/dev/null | grep -q ios-build' 2>/dev/null \
        && echo "  OK   ios-build MCP registered" || echo "  --   ios-build MCP not registered"
      if box_gateway_reachable "$name"; then
        box_gateway_ok=1
        echo "  OK   box can reach host gateway ($GATEWAY_HOST:$GATEWAY_PORT)"
      elif ! gateway_up; then
        echo "  FAIL box cannot reach host gateway — run 'xcbox up' to start/restart it"
      elif ! container_host_bridge_configured; then
        echo "  FAIL box cannot reach host gateway — run: sudo container system dns create $GATEWAY_HOST --localhost $GATEWAY_LOCALHOST_IP"
      else
        echo "  FAIL box cannot reach host gateway — run 'xcbox doctor', then 'xcbox stop' and 'xcbox up'"
      fi
      if [ "$box_gateway_ok" = 1 ]; then
        box_mcp_ready "$name" \
          && echo "  OK   real MCP session lists Xcode build tools" \
          || echo "  FAIL MCP session failed — inspect 'xcbox logs', then run 'xcbox stop --gateway' and 'xcbox up'"
      fi
      box_ssh_agent_ready "$name" \
        && echo "  OK   forwarded SSH agent has an identity" \
        || echo "  FAIL forwarded SSH agent unavailable/empty — run host 'ssh-add', then 'xcbox rm' and 'xcbox up'"
    fi
  else
    echo "  --   no box for this project (run 'xcbox up')"
  fi
}

cmd_logs() {
  local follow=0 lines="${XCBOX_LOG_LINES:-50}" log="$XCBOX_HOME/gateway.log"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -f|--follow) follow=1; shift ;;
      -n|--lines)
        [ "$#" -ge 2 ] || { echo "xcbox: $1 requires a line count" >&2; return 2; }
        lines="$2"; shift 2 ;;
      --lines=*) lines="${1#*=}"; shift ;;
      --) shift; [ "$#" -eq 0 ] || { echo "xcbox: unexpected logs argument '$1'" >&2; return 2; } ;;
      *) echo "xcbox: unknown logs option '$1' (use -f or --lines N)" >&2; return 2 ;;
    esac
  done
  case "$lines" in ''|*[!0-9]*) echo "xcbox: log line count must be a positive integer" >&2; return 2 ;; esac
  [ "$lines" -gt 0 ] || { echo "xcbox: log line count must be a positive integer" >&2; return 2; }
  if [ -L "$log" ]; then
    echo "xcbox: refusing symlinked gateway log at $log" >&2
    return 1
  fi
  if [ ! -f "$log" ]; then
    echo "xcbox: no gateway log yet at $log"
    return 0
  fi
  if [ "$follow" = 1 ]; then
    exec tail -n "$lines" -f "$log"
  fi
  tail -n "$lines" "$log"
}

cmd_list() {
  local inventory
  [ "$#" -eq 0 ] || { echo "xcbox: list takes no arguments" >&2; return 2; }
  node_supported || { echo "xcbox: Node.js 20+ is required to read container inventory" >&2; return 1; }
  command -v container >/dev/null 2>&1 || { echo "xcbox: Apple container CLI is not installed" >&2; return 1; }
  if ! inventory=$(container ls -a --format json 2>/dev/null); then
    echo "xcbox: container daemon is unavailable — run 'container system start'" >&2
    return 1
  fi
  printf '%s\n' "$inventory" | node "$DIR/xcbox-list.mjs" "$XCBOX_HOME" "$XCBOX_BOX_HOME_ROOT" "$XCBOX_PROJECT_METADATA_ROOT"
}

cmd_stop() {
  local requested proj name
  requested="${PROJECT:-$(pwd)}"
  proj=$(project_context_dir "$requested") || return
  name=$(sanitize_name "$proj")
  if legacy_box_detected "$proj" "$name"; then
    print_legacy_box_migration "$proj" "$name"
    return 1
  fi
  if box_running "$name"; then echo "==> stopping box '$name'"; container stop "$name" >/dev/null 2>&1 || true
  else echo "xcbox: box '$name' not running"; fi
  if [ "${1:-}" = "--gateway" ]; then
    stop_gateway
  fi
}

cmd_rm() {
  local requested proj name
  requested="${PROJECT:-$(pwd)}"
  proj=$(project_context_dir "$requested") || return
  name=$(sanitize_name "$proj")
  if legacy_box_detected "$proj" "$name"; then
    print_legacy_box_migration "$proj" "$name"
    return 1
  fi
  if box_exists "$name"; then
    echo "==> removing box '$name'"
    container stop "$name" >/dev/null 2>&1 || true
    container rm "$name" >/dev/null 2>&1 || true
  else echo "xcbox: no box '$name' to remove"; fi
}

main() {
  local cmd="${1:-up}"; shift || true
  case "$cmd" in
    up)      cmd_up "$@" ;;
    list)    cmd_list "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    status)  cmd_status "$@" ;;
    stop)    cmd_stop "$@" ;;
    logs)    cmd_logs "$@" ;;
    rm)      cmd_rm "$@" ;;
    help|-h|--help) usage ;;
    *)       echo "xcbox: unknown command '$cmd'" >&2; usage; exit 2 ;;
  esac
}
main "$@"
